{
  "name": "shipmobile",
  "version": "0.1.2",
  "description": "Ship React Native/Expo apps to App Store & Play Store — CLI + MCP server",
  "type": "module",
  "bin": {
    "shipmobile": "./dist/index.js",
    "shipmobile-mcp": "./dist/mcp.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ACRLABSDEV/shipmobile.git"
  },
  "homepage": "https://github.com/ACRLABSDEV/shipmobile#readme",
  "bugs": {
    "url": "https://github.com/ACRLABSDEV/shipmobile/issues"
  },
  "author": "ACR Labs <acanino@acrlabs.io>",
  "exports": {
    ".": "./dist/index.js",
    "./mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsup && cp -r assets dist/",
    "dev": "tsup --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "react-native",
    "expo",
    "app-store",
    "play-store",
    "cli",
    "mcp",
    "deployment"
  ],
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gradient-string": "^3.0.0",
    "jose": "^6.1.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.32.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
